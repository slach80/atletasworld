# Local dev environment — services provided by docker-compose.dev.yml
# Copy this to .env for local development:
#   cp .env.dev .env
# Then update STRIPE_WEBHOOK_SECRET with the value printed by stripe-cli on startup.

SECRET_KEY=dev-secret-key-not-for-production-use-only
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (docker-compose.dev.yml)
DATABASE_URL=postgres://atletasworld:atletasworld@localhost:5433/atletasworld_dev

# Redis (docker-compose.dev.yml)
REDIS_URL=redis://localhost:6379/0

# Stripe test keys — get from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLIC_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
# Copy the webhook signing secret printed by stripe-cli on startup:
#   "Ready! Your webhook signing secret is whsec_xxxx (^C to quit)"
STRIPE_WEBHOOK_SECRET=whsec_replace_me_from_stripe_cli_output

TAX_RATE=0.0

# Email → Mailhog (docker-compose.dev.yml) — view at http://localhost:8025
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Feature flags — enable as needed for local testing
CELERY_ENABLED=False
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db

SMS_ENABLED=False
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1234567890

PUSH_NOTIFICATIONS_ENABLED=False
VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx

PRODUCTION_EMAIL_ENABLED=False

SITE_URL=http://localhost:8000
DEFAULT_FROM_EMAIL=noreply@atletasworld.local
CORS_ALLOWED_ORIGINS=http://localhost:3000
